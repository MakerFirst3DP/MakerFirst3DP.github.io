---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="MakerFirst — Hardware, AI & Firmware Consulting">
  <main id="main">
    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center overflow-hidden">
      <!-- Parallax background element -->
      <div
        class="parallax-bg absolute inset-0 opacity-[0.04] pointer-events-none"
        aria-hidden="true"
      >
        <svg
          class="w-full h-full"
          viewBox="0 0 1200 800"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <!-- Circuit/grid pattern -->
          <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
            <circle cx="30" cy="30" r="1.5" fill="currentColor" />
            <line x1="30" y1="0" x2="30" y2="60" stroke="currentColor" stroke-width="0.5" />
            <line x1="0" y1="30" x2="60" y2="30" stroke="currentColor" stroke-width="0.5" />
          </pattern>
          <rect width="1200" height="800" fill="url(#grid)" />
        </svg>
      </div>

      <div class="relative mx-auto max-w-4xl px-6 py-24 md:py-32">
        <p
          class="mb-4 text-sm font-medium tracking-wide uppercase text-brand-secondary"
        >
          Engineering Consulting
        </p>
        <h1
          class="text-4xl font-bold tracking-tight text-brand-primary md:text-5xl lg:text-6xl"
        >
          We build the hard&nbsp;stuff.
        </h1>
        <p
          class="mt-6 max-w-2xl text-lg text-neutral-600 md:text-xl"
        >
          MakerFirst helps teams ship launch hardware, deploy AI agents, and
          develop production firmware — from prototype to production.
        </p>
        <div class="mt-8">
          <a
            href="#contact"
            class="inline-flex items-center gap-2 rounded-[var(--radius)] bg-brand-accent px-6 py-3 text-base font-semibold text-brand-primary shadow-sm transition-colors hover:bg-brand-accent-hover focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-accent"
            style="transition-duration: var(--duration-fast);"
          >
            Work with us
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12h14" />
              <path d="m12 5 7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  import { initParallax } from '../scripts/animations';

  document.addEventListener('astro:page-load', () => {
    initParallax('.parallax-bg', 0.3);
  });
</script>
