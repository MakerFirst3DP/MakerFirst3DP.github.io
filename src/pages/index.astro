---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/sections/Hero.astro';
import Product from '../components/sections/Product.astro';
import Manifesto from '../components/sections/Manifesto.astro';
import Community from '../components/sections/Community.astro';
import BuildProtocol from '../components/sections/BuildProtocol.astro';
import CTA from '../components/sections/CTA.astro';
import Footer from '../components/sections/Footer.astro';
---

<BaseLayout
  title="MakerFirst — 3D Printable Gadgets for Makers"
  description="MakerFirst creates 3D printable everyday gadgets for Makers. Open source, community-driven. First product line: Espresso gear with the AirShaker."
>
  <Nav />
  <main id="main">
    <Hero />
    <Product />
    <Manifesto />
    <Community />
    <BuildProtocol />
    <CTA />
  </main>
  <Footer />
</BaseLayout>