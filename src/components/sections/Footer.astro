---
const currentYear = new Date().getFullYear();

const links = [
  { href: '#services', label: 'Services' },
  { href: '#process', label: 'Process' },
  { href: '#about', label: 'About' },
  { href: 'mailto:hello@makerfirst.ca', label: 'Contact' },
];

const socials = [
  {
    href: 'https://linkedin.com/company/makerfirst',
    label: 'LinkedIn',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>`,
  },
  {
    href: 'https://github.com/MakerFirst3DP',
    label: 'GitHub',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>`,
  },
];
---

<footer class="bg-neutral-950 border-t border-white/[0.06]">
  <div class="mx-auto max-w-6xl px-6 py-16">

    <div class="grid grid-cols-1 gap-12 md:grid-cols-3">

      <!-- Brand -->
      <div>
        <a href="#" class="inline-flex items-center gap-2 font-bold text-white text-lg tracking-tight mb-4" aria-label="MakerFirst home">
          <svg width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <rect width="32" height="32" rx="6" fill="#f59e0b"/>
            <text x="16" y="22" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-weight="700" font-size="14" fill="#0f172a">MF</text>
          </svg>
          MakerFirst
        </a>
        <p class="text-sm text-white/40 leading-relaxed max-w-xs">
          Engineering consulting for Launch Hardware, AI Agents, and Firmware Development.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-xs font-semibold tracking-[0.12em] uppercase text-white/30 mb-4">Navigation</h3>
        <ul class="flex flex-col gap-3 list-none m-0 p-0" role="list">
          {links.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class="text-sm text-white/50 hover:text-white transition-colors"
                style="transition-duration: var(--duration-fast);"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact + Socials -->
      <div>
        <h3 class="text-xs font-semibold tracking-[0.12em] uppercase text-white/30 mb-4">Contact</h3>
        <a
          href="mailto:hello@makerfirst.ca"
          class="text-sm text-white/50 hover:text-white transition-colors block mb-6"
          style="transition-duration: var(--duration-fast);"
        >
          hello@makerfirst.ca
        </a>

        <div class="flex items-center gap-4">
          {socials.map(({ href, label, icon }) => (
            <a
              href={href}
              class="text-white/30 hover:text-white/70 transition-colors"
              style="transition-duration: var(--duration-fast);"
              aria-label={label}
              rel="noopener noreferrer"
              target="_blank"
              set:html={icon}
            />
          ))}
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-white/[0.06] flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-white/25">
        &copy; {currentYear} MakerFirst. All rights reserved.
      </p>
      <p class="text-xs text-white/25">
        makerfirst.ca
      </p>
    </div>

  </div>
</footer>
