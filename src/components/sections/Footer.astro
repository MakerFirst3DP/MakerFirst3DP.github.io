---
import githubSvg from '/public/svg/social/github.svg?raw';

const currentYear = new Date().getFullYear();

const links = [
  { href: '#product', label: 'Product' },
  { href: '#manifesto', label: 'Manifesto' },
  { href: '#community', label: 'Community' },
  { href: '#build', label: 'Build' },
];

const resourceLinks = [
  { href: 'https://github.com/MakerFirst3DP', label: 'GitHub Repository' },
  { href: 'https://github.com/MakerFirst3DP', label: 'STL Downloads' },
  { href: 'https://github.com/MakerFirst3DP', label: 'Print Profiles' },
];
---

<!--
  FOOTER — Technical, precise, no filler.
  Uses: [WIDGET] Technical Label, [WIDGET] Ghost Border
-->

<footer class="border-t border-outline" style="background-color: var(--color-surface-dim);">
  <div class="max-w-[1440px] mx-auto py-10 px-4">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-start">

      <!-- Brand -->
      <div class="md:col-span-5 space-y-4">
        <a href="#" class="inline-flex items-center gap-3" aria-label="MakerFirst home">
          <img src="/svg/logo/logomark.svg" width="28" height="28" alt="" aria-hidden="true" />
          <span class="font-display font-bold text-base tracking-tighter uppercase text-on-surface">MakerFirst</span>
        </a>
        <p class="text-[11px] text-on-surface-variant max-w-xs leading-relaxed uppercase tracking-wider">
          3D printable gadgets for makers. Open source hardware. Every design starts a conversation.
        </p>
      </div>

      <!-- Links -->
      <div class="md:col-span-3 flex flex-col gap-2">
        <span class="technical-label block mb-1">Navigation</span>
        {links.map(({ href, label }) => (
          <a
            href={href}
            class="text-[11px] text-on-surface-variant hover:text-on-surface uppercase tracking-wider transition-colors"
            style="transition-duration: var(--duration-fast);"
          >
            {label}
          </a>
        ))}
      </div>

      <!-- Resources -->
      <div class="md:col-span-2 flex flex-col gap-2">
        <span class="technical-label block mb-1">Resources</span>
        {resourceLinks.map(({ href, label }) => (
          <a
            href={href}
            class="text-[11px] text-on-surface-variant hover:text-on-surface uppercase tracking-wider transition-colors"
            target="_blank"
            rel="noopener noreferrer"
            style="transition-duration: var(--duration-fast);"
          >
            {label}
          </a>
        ))}
      </div>

      <!-- Social + Contact -->
      <div class="md:col-span-2 flex flex-col gap-2">
        <span class="technical-label block mb-1">Connect</span>
        <a
          href="https://github.com/MakerFirst3DP"
          class="w-5 h-5 block text-on-surface-variant hover:text-on-surface transition-colors"
          style="transition-duration: var(--duration-fast);"
          aria-label="GitHub"
          target="_blank"
          rel="noopener noreferrer"
          set:html={githubSvg}
        />
        <a
          href="mailto:hello@makerfirst.ca"
          class="text-[11px] text-on-surface-variant hover:text-on-surface uppercase tracking-wider transition-colors"
          style="transition-duration: var(--duration-fast);"
        >
          hello@makerfirst.ca
        </a>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-6 border-t border-outline flex flex-col md:flex-row justify-between items-center gap-4 text-[9px] font-display text-on-surface-variant uppercase tracking-[0.2em]">
      <span>&copy; {currentYear} MakerFirst. All designs released under CERN-OHL-S.</span>
      <span>makerfirst.ca</span>
    </div>
  </div>
</footer>