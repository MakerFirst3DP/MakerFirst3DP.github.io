---
import linkedinSvg from '/public/svg/social/linkedin.svg?raw';
import githubSvg from '/public/svg/social/github.svg?raw';

const currentYear = new Date().getFullYear();

const links = [
  { href: '#services', label: 'Services' },
  { href: '#process', label: 'Process' },
  { href: '#about', label: 'About' },
  { href: 'mailto:hello@makerfirst.ca', label: 'Contact' },
];

const socials = [
  { href: 'https://linkedin.com/company/makerfirst', label: 'LinkedIn', svg: linkedinSvg },
  { href: 'https://github.com/MakerFirst3DP', label: 'GitHub', svg: githubSvg },
];
---

<footer class="bg-neutral-950 border-t border-white/[0.06]">
  <div class="mx-auto max-w-6xl px-6 py-16">

    <div class="grid grid-cols-1 gap-12 md:grid-cols-3">

      <!-- Brand -->
      <div>
        <a href="#" class="inline-flex items-center gap-2 font-bold text-white text-lg tracking-tight mb-4" aria-label="MakerFirst home">
          <img src="/svg/logo/logomark-light.svg" width="32" height="32" alt="" aria-hidden="true" />
          MakerFirst
        </a>
        <p class="text-sm text-white/40 leading-relaxed max-w-xs">
          Engineering consulting for Launch Hardware, AI Agents, and Firmware Development.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-xs font-semibold tracking-[0.12em] uppercase text-white/30 mb-4">Navigation</h3>
        <ul class="flex flex-col gap-3 list-none m-0 p-0" role="list">
          {links.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class="text-sm text-white/50 hover:text-white transition-colors"
                style="transition-duration: var(--duration-fast);"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact + Socials -->
      <div>
        <h3 class="text-xs font-semibold tracking-[0.12em] uppercase text-white/30 mb-4">Contact</h3>
        <a
          href="mailto:hello@makerfirst.ca"
          class="text-sm text-white/50 hover:text-white transition-colors block mb-6"
          style="transition-duration: var(--duration-fast);"
        >
          hello@makerfirst.ca
        </a>

        <div class="flex items-center gap-4">
          {socials.map(({ href, label, svg }) => (
            <a
              href={href}
              class="w-5 h-5 block text-white/30 hover:text-white/70 transition-colors"
              style="transition-duration: var(--duration-fast);"
              aria-label={label}
              rel="noopener noreferrer"
              target="_blank"
              set:html={svg}
            />
          ))}
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-white/[0.06] flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-white/25">
        &copy; {currentYear} MakerFirst. All rights reserved.
      </p>
      <p class="text-xs text-white/25">
        makerfirst.ca
      </p>
    </div>

  </div>
</footer>
