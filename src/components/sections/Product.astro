---
const specs = [
  { label: 'DISTRIBUTION METHOD', value: 'Precision Air (Vortex)' },
  { label: 'REPLACES', value: 'WDT + Manual Distribution' },
  { label: 'MATERIAL PROTOCOL', value: 'PETG-HF' },
  { label: 'PRECISION TOLERANCE', value: '+/- 0.05 mm' },
  { label: 'LAYER HEIGHT OPT', value: '0.4 mm' },
  { label: 'ESTIMATED PRINT', value: '2h 14m @ 250mm/s' },
  { label: 'PRODUCT CATEGORY', value: 'New Category (Novel)' },
  { label: 'LICENSE', value: 'CERN-OHL-S (Open Source)' },
];
---

<!--
  PRODUCT SECTION — Deep-Dive Tech Specs
  Uses: [WIDGET] Schematic Callout, [WIDGET] Spec Sheet,
        [WIDGET] Technical Label, [WIDGET] Ghost Border
-->

<section id="product" class="py-16 bg-surface-low border-b border-outline">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

      <!-- Product Images: CAD + Real Print -->
      <div class="space-y-4">
        <!-- CAD Screenshot -->
        <div class="relative bg-surface-dim border border-outline overflow-hidden rounded-[var(--radius)]">
          <img
            src="/images/AirShakerCad.png"
            alt="AirShaker CAD model — Onshape design view"
            class="w-full h-auto object-contain"
          />
          <!-- Bottom labels: plain text, no rectangles. Left=orange, Right=blue. -->
          <span class="absolute bottom-3 left-3 font-display text-xs uppercase tracking-widest z-10" style="color:#FF6B00; text-shadow:0 0 0 #000, 1px 1px 0 #000, -1px -1px 0 #000, 1px -1px 0 #000, -1px 1px 0 #000;">AIRSHAKER / REV C</span>
          <a href="https://cad.onshape.com/documents/87e3546070b02d8f0ccd361f/w/2e7f911bc6f322aa95b8ad4b/e/3465917065ae54ea0a6821cd?renderMode=0&uiState=69dd83e4920ad55a6876bbb7" target="_blank" rel="noopener noreferrer" class="absolute bottom-3 right-3 font-display text-xs uppercase tracking-widest z-10 hover:underline" style="color:#b6c4ff; text-shadow:0 0 0 #000, 1px 1px 0 #000, -1px -1px 0 #000, 1px -1px 0 #000, -1px 1px 0 #000;">ONSHAPE CAD ↗</a>
          <!-- [WIDGET] Schematic Callouts -->
          <div class="absolute top-[28%] right-[15%] flex items-center gap-2">
            <div class="callout-dot"></div>
            <div class="callout-line"></div>
            <span class="font-display text-[9px] uppercase tracking-widest text-primary bg-surface-dim/90 px-1.5 py-0.5">Vortex_Chamber</span>
          </div>
          <div class="absolute bottom-[18%] left-[20%] flex items-center gap-2">
            <div class="callout-dot"></div>
            <div class="callout-line"></div>
            <span class="font-display text-[9px] uppercase tracking-widest text-primary bg-surface-dim/90 px-1.5 py-0.5">Air_Pump</span>
          </div>
        </div>

        <!-- Real Printed Product -->
        <div class="relative border border-outline overflow-hidden rounded-[var(--radius)]" style="background-color: #ffffff;">
          <img
            src="/images/AirShaker.png"
            alt="AirShaker — printed and assembled real product photo"
            class="w-full h-auto object-cover"
          />
          <span class="absolute bottom-3 left-3 font-display text-xs uppercase tracking-widest z-10" style="color:#FF6B00; text-shadow:0 0 0 #000, 1px 1px 0 #000, -1px -1px 0 #000, 1px -1px 0 #000, -1px 1px 0 #000;">AIRSHAKER / REV C</span>
          <span class="absolute bottom-3 right-3 font-display text-xs uppercase tracking-widest z-10" style="color:#b6c4ff; text-shadow:0 0 0 #000, 1px 1px 0 #000, -1px -1px 0 #000, 1px -1px 0 #000, -1px 1px 0 #000;">0.4mm · PETG-HF</span>
        </div>
      </div>

      <div class="space-y-8">
        <header class="space-y-2">
          <!-- [WIDGET] Technical Label -->
          <p class="technical-label">System Identification</p>
          <h2 class="font-display text-4xl font-bold tracking-tighter text-on-surface">
            MF AirShaker Rev C
          </h2>
          <p class="text-on-surface-variant font-light leading-relaxed">
            The first product in the espresso gear line. A 3D printable tool that uses precision air channels to distribute coffee grounds evenly in the puck — replacing mechanical WDT tools entirely. Novel category. Better taste in the cup, even with a cheap grinder.
          </p>
        </header>

        <!-- [WIDGET] Spec Sheet (Technical Data Table) -->
        <div class="bg-surface-dim border border-outline overflow-hidden rounded-[var(--radius)]">
          <div class="px-4 py-2 border-b border-outline bg-surface-high font-display text-[10px] uppercase tracking-widest text-on-surface-variant">
            Physical Parameters
          </div>
          <table class="w-full text-left font-display text-xs">
            <tbody>
              {specs.map((spec, i) => (
                <tr class={i % 2 === 0 ? 'bg-surface-dim' : 'bg-surface-low'}>
                  <th class="px-4 py-3 font-medium text-on-surface-variant uppercase tracking-wider text-[10px]">{spec.label}</th>
                  <td class="px-4 py-3 text-on-surface text-right">{spec.value}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <a
            href="https://github.com/MakerFirst3DP"
            class="flex items-center justify-center gap-3 px-6 py-4 bg-primary text-black font-display font-bold uppercase tracking-widest text-xs hover:brightness-110 transition-all rounded-[var(--radius)]"
            style="background-color: var(--color-primary);"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
            Download STL
          </a>
          <a
            href="https://github.com/MakerFirst3DP"
            class="flex items-center justify-center gap-3 px-6 py-4 bg-surface border border-outline text-on-surface font-display font-bold uppercase tracking-widest text-xs hover:bg-surface-high transition-all rounded-[var(--radius)]"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            Source Files
          </a>
        </div>
      </div>
    </div>
  </div>
</section>