---
const steps = [
  {
    number: '01',
    title: 'Discovery call',
    description:
      'We spend 45 minutes understanding your project, constraints, and goals. No pitch deck — just an honest technical conversation.',
  },
  {
    number: '02',
    title: 'Technical scoping',
    description:
      "We produce a written scope document: what we'll build, how we'll build it, what you'll need to provide, timeline, and a fixed or capped budget.",
  },
  {
    number: '03',
    title: 'Engagement kickoff',
    description:
      "We agree on the scope, sign a straightforward contract, and schedule the kickoff. You get a dedicated Slack channel and a weekly update cadence.",
  },
  {
    number: '04',
    title: 'Iterative delivery',
    description:
      'We deliver in milestones with review checkpoints. You see progress every week — not just at the end. Course corrections happen early, not late.',
  },
  {
    number: '05',
    title: 'Handoff & support',
    description:
      'Documented repos, organized design files, and a live handoff session. We offer post-delivery support and are available for follow-on work.',
  },
];
---

<section id="process" class="py-24 bg-neutral-100 md:py-32">
  <div class="mx-auto max-w-6xl px-6">

    <div class="max-w-2xl mb-16">
      <p class="mb-3 text-xs font-semibold tracking-[0.15em] uppercase text-brand-accent">
        How we work
      </p>
      <h2 class="text-3xl font-bold tracking-tight text-brand-primary md:text-4xl">
        No surprises. No vague scope.
      </h2>
      <p class="mt-4 text-lg text-neutral-600">
        Every engagement follows the same structure. You always know where things
        stand and what comes next.
      </p>
    </div>

    <!-- Steps: simple vertical list with connecting line -->
    <div class="relative max-w-xl">
      <!-- Vertical connector line -->
      <div class="absolute left-5 top-6 bottom-6 w-px bg-neutral-300" aria-hidden="true"></div>

      <ol class="relative flex flex-col gap-8 list-none m-0 p-0" role="list">
        {steps.map((step) => (
          <li class="process-step relative flex gap-6">
            <!-- Number bubble -->
            <div class="relative z-10 shrink-0">
              <span class="flex h-11 w-11 items-center justify-center rounded-full bg-brand-primary text-sm font-bold text-brand-accent shadow-md">
                {step.number}
              </span>
            </div>
            <!-- Content -->
            <div class="pt-2 pb-2">
              <h3 class="text-lg font-semibold text-brand-primary mb-2">{step.title}</h3>
              <p class="text-base text-neutral-600 leading-relaxed">{step.description}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>

  </div>
</section>

<script>
  import { initStaggerReveal } from '../../scripts/animations';
  document.addEventListener('astro:page-load', () => {
    initStaggerReveal('#process', '.process-step', { stagger: 0.1, distance: 20 });
  });
</script>
