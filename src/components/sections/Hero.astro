---

<!--
  HERO SECTION — "The Laboratory"
  Uses: [WIDGET] Precision Grid, [WIDGET] Version Badge, [WIDGET] Technical Label
  The hero is product-focused: slogan, tagline, product visual with spec data.
-->

<section
  class="relative min-h-[80vh] flex flex-col justify-center precision-grid overflow-hidden px-4 border-b border-outline"
  aria-label="Hero"
  style="background-color: var(--color-surface-lowest);"
>
  <div class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-12 gap-6 items-center">
    <div class="lg:col-span-7 space-y-6">
      <!-- [WIDGET] Version Badge — First product line indicator -->
      <div class="version-badge">
        <span class="status-dot"></span>
        FIRST PRODUCT LINE: ESPRESSO GEAR
      </div>

      <h1 class="font-display text-6xl md:text-8xl font-bold tracking-tighter leading-[0.9] uppercase text-on-surface">
        One size<br/><span class="text-primary italic">doesn't</span><br/>fit all.
      </h1>

      <p class="max-w-xl text-lg text-on-surface-variant font-light leading-relaxed border-l-2 border-outline pl-4">
        We don't optimize the old. We put something new on the table. Open-source 3D printable gadgets designed with makers, for makers. Every design is a starting point — fork it, modify it, make it yours.
      </p>

      <div class="flex flex-wrap gap-4 pt-2">
        <a
          href="#product"
          class="inline-flex items-center gap-2 px-8 py-4 bg-primary text-on-primary-container font-display font-bold uppercase tracking-widest text-sm hover:brightness-110 transition-all rounded-[var(--radius)]"
          style="background-color: var(--color-primary); color: #000;"
        >
          Download STL
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
        </a>
        <a
          href="#community"
          class="inline-flex items-center gap-2 px-8 py-4 bg-surface border border-outline text-on-surface font-display font-bold uppercase tracking-widest text-sm hover:bg-surface-high transition-all rounded-[var(--radius)]"
        >
          View Source
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        </a>
      </div>
    </div>

    <div class="lg:col-span-5 relative hidden lg:block">
      <div class="aspect-square bg-surface border border-outline relative overflow-hidden rounded-[var(--radius)]">
        <img
          src="/product-hero.jpg"
          alt="MK4S 3D printer — the tool behind every MakerFirst design"
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-surface-dim/80 via-transparent to-transparent"></div>
        <div class="absolute bottom-4 left-4 font-display text-[10px] text-primary uppercase tracking-widest">AIR-PUCK / REV C</div>
        <div class="absolute bottom-4 right-4 font-display text-[10px] text-on-surface-variant uppercase tracking-widest">0.12mm LAYER HEIGHT</div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-30" aria-hidden="true">
    <span class="font-display text-[10px] text-on-surface-variant uppercase tracking-widest">Scroll</span>
    <svg width="12" height="20" viewBox="0 0 12 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <rect x="1" y="1" width="10" height="18" rx="5" stroke="currentColor"/>
      <line x1="6" y1="4" x2="6" y2="8" stroke="currentColor"/>
    </svg>
  </div>
</section>