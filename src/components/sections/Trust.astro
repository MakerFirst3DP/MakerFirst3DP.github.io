---
const signals = [
  {
    stat: '12 wks',
    label: 'Typical time from kickoff to first production run',
  },
  {
    stat: '3',
    label: 'Core engineering disciplines under one roof',
  },
  {
    stat: '100%',
    label: 'Engagements delivered with full documentation and handoff',
  },
];

const qualifiers = [
  'Senior engineers on every engagement — no juniors subbing in',
  'Fixed-scope or capped-cost contracts — no open-ended billing',
  'Canadian company, plain contracts, no legal surprises',
  'Available for follow-on work and long-term retainers',
];
---

<section id="trust" class="py-24 bg-white md:py-32">
  <div class="mx-auto max-w-6xl px-6">

    <!-- Stats row -->
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-3 mb-16">
      {signals.map((s) => (
        <div class="trust-stat flex flex-col border-l-2 border-brand-accent pl-6">
          <span class="text-4xl font-bold text-brand-primary tracking-tight mb-1">{s.stat}</span>
          <span class="text-sm text-neutral-600 leading-snug">{s.label}</span>
        </div>
      ))}
    </div>

    <!-- Qualifiers -->
    <div class="grid grid-cols-1 gap-16 lg:grid-cols-2 items-start">

      <div class="trust-copy">
        <p class="mb-3 text-xs font-semibold tracking-[0.15em] uppercase text-brand-accent">
          Why MakerFirst
        </p>
        <h2 class="text-3xl font-bold tracking-tight text-brand-primary md:text-4xl">
          The engineering firm you can hold accountable.
        </h2>
        <p class="mt-4 text-lg text-neutral-600 leading-relaxed">
          Consulting firms promise senior talent and deliver juniors. Agencies
          promise fixed-price and expand scope. We operate differently — small,
          accountable, and transparent from day one.
        </p>
      </div>

      <ul class="flex flex-col gap-4 list-none m-0 p-0" role="list">
        {qualifiers.map((q) => (
          <li class="trust-qualifier flex items-start gap-3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-accent shrink-0 mt-0.5" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span class="text-base text-brand-secondary">{q}</span>
          </li>
        ))}
      </ul>

    </div>
  </div>
</section>

<script>
  import { initScrollReveal, initStaggerReveal } from '../../scripts/animations';
  document.addEventListener('astro:page-load', () => {
    initStaggerReveal('#trust', '.trust-stat', { stagger: 0.1, distance: 16 });
    initScrollReveal('.trust-copy');
    initStaggerReveal('#trust', '.trust-qualifier', { stagger: 0.08, distance: 16 });
  });
</script>
