---
import sectionDivider from '/public/svg/decorative/section-divider.svg?raw';

const principles = [
  {
    label: 'Engineers, not generalists',
    body: 'We work deep in the stack. Every engagement is led by engineers who have shipped real products — not account managers or consultants reading playbooks.',
  },
  {
    label: 'Scope before starting',
    body: 'We scope every engagement before we begin. You get a clear technical plan, timeline, and cost before a single line of code or trace is drawn.',
  },
  {
    label: 'Handoff-ready output',
    body: 'We document everything. Schematics, firmware repos, agent architectures, and runbooks — all organized for whoever maintains it next.',
  },
];
---

<!-- Section divider: white → dark transition. currentColor inherits navy from parent. -->
<div class="bg-white overflow-hidden leading-none text-brand-primary" aria-hidden="true">
  <Fragment set:html={sectionDivider} />
</div>

<section id="about" class="py-24 bg-brand-primary md:py-32">
  <div class="mx-auto max-w-6xl px-6">

    <div class="grid grid-cols-1 gap-16 lg:grid-cols-2 lg:gap-24 items-start">

      <!-- Left: intro copy -->
      <div class="about-intro">
        <p class="mb-3 text-xs font-semibold tracking-[0.15em] uppercase text-brand-accent/80">
          About
        </p>
        <h2 class="text-3xl font-bold tracking-tight text-white md:text-4xl leading-snug">
          A small team.<br />A tight scope.<br />Shipped on time.
        </h2>
        <p class="mt-6 text-lg text-white/60 leading-relaxed">
          MakerFirst is a boutique engineering consultancy. We take on a small number of
          engagements at a time and treat each one as if it were our own product.
        </p>
        <p class="mt-4 text-lg text-white/60 leading-relaxed">
          We work with founders, product teams, and established companies that need
          senior-level engineering expertise without the overhead of hiring full-time.
          Hardware is hard. We know where the landmines are.
        </p>

        <div class="mt-8 flex items-center gap-4">
          <div class="h-px flex-1 bg-white/10" aria-hidden="true"></div>
          <span class="text-sm text-white/40 italic">Canada-based. Available globally.</span>
          <div class="h-px flex-1 bg-white/10" aria-hidden="true"></div>
        </div>
      </div>

      <!-- Right: principles -->
      <div class="flex flex-col gap-6">
        {principles.map((p, i) => (
          <div class="about-principle flex gap-6">
            <div class="shrink-0 mt-1">
              <span class="flex h-7 w-7 items-center justify-center rounded-full bg-brand-accent/10 border border-brand-accent/20 text-xs font-bold text-brand-accent">
                {String(i + 1).padStart(2, '0')}
              </span>
            </div>
            <div>
              <h3 class="text-base font-semibold text-white mb-2">{p.label}</h3>
              <p class="text-base text-white/55 leading-relaxed">{p.body}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<script>
  import { initScrollReveal, initStaggerReveal } from '../../scripts/animations';
  document.addEventListener('astro:page-load', () => {
    initScrollReveal('.about-intro');
    initStaggerReveal('#about', '.about-principle', { stagger: 0.1 });
  });
</script>
