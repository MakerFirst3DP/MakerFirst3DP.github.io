<div class="bs-canvas" id="bannerCanvas">
  <div class="bs-seam tl"></div>
  <div class="bs-seam tr"></div>
  <div class="bs-seam bl"></div>
  <div class="bs-seam br"></div>

  <div class="bs-frame">
    <section class="bs-top">
      <div class="bs-grid"></div>

      <section class="bs-zone bs-zone-sponsor">
        <div class="bs-sponsor-box ghost-border">
          <span class="bs-sponsor-text" data-field="sponsorLabel">SPONSOR LOGO</span>
        </div>
      </section>

      <section class="bs-zone bs-zone-brand">
        <img src="/logo.png" alt="MakerFirst" class="bs-logo" />
        <h1 class="bs-brand-name">Maker<span class="bs-brand-first">First</span></h1>
      </section>

      <section class="bs-zone bs-zone-slogan">
        <div class="bs-filament-bar filament-accent"></div>
        <p class="bs-slogan-text" data-field="slogan">One size doesn't fit all</p>
      </section>

      <div class="bs-top-fade" aria-hidden="true"></div>
    </section>

    <section class="bs-body">
      <div class="bs-mission-block">
        <p class="technical-label">Why We Exist</p>
        <p class="bs-mission-copy" data-field="missionCopy">MakerFirst builds never-before-seen product categories for real makers. We release open hardware, invite modification, and treat every print as the next design review.</p>
      </div>

      <div class="bs-body-grid">
        <div class="bs-body-col bs-body-col-left">
          <div class="bs-body-head">
            <p class="technical-label">System Identification</p>
            <p class="bs-cad-label" data-field="cadLabel">MF AIRSHAKER REV C / ONSHAPE CAD</p>
          </div>

          <div class="bs-cad-card">
            <div class="bs-cad-wrap">
              <img src="/images/AirShakerCad.png" alt="AirShaker CAD model" />
              <div class="bs-callouts">
                <div class="bs-callout vortex">
                  <div class="bs-callout-dot"></div>
                  <div class="bs-callout-line"></div>
                  <span class="bs-callout-label" data-field="callout1">VORTEX CHAMBER</span>
                </div>
                <div class="bs-callout pump">
                  <div class="bs-callout-dot"></div>
                  <div class="bs-callout-line"></div>
                  <span class="bs-callout-label" data-field="callout2">AIR PUMP</span>
                </div>
                <div class="bs-callout nozzle">
                  <div class="bs-callout-dot"></div>
                  <div class="bs-callout-line"></div>
                  <span class="bs-callout-label" data-field="callout3">PRECISION NOZZLE</span>
                </div>
              </div>
            </div>
          </div>

          <div class="bs-cad-meta">
            <span class="bs-meta-chip">FIRST PRODUCT LINE</span>
            <span class="bs-meta-chip">ESPRESSO GEAR</span>
          </div>
        </div>

        <div class="bs-body-col bs-body-col-right">
          <p class="technical-label">Open Hardware</p>
          <h2 class="bs-copy-head" data-field="message1">NEW CATEGORIES</h2>
          <p class="bs-copy-sub" data-field="message2">NOT BETTER CLONES</p>
          <p class="bs-copy-body" data-field="description">Open-source 3D printable gadgets built with makers, not for them.</p>

          <div class="bs-proof-list">
            <div class="bs-proof-item"><span class="bs-proof-dot"></span><span>COMMUNITY DRIVEN</span></div>
            <div class="bs-proof-item"><span class="bs-proof-dot"></span><span>REAL PRINTERS</span></div>
            <div class="bs-proof-item"><span class="bs-proof-dot"></span><span>CERN-OHL-S</span></div>
          </div>
        </div>
      </div>

      <div class="bs-body-footer ghost-border">
        <div class="bs-footer-copy">
          <p class="technical-label">Scan To Get Files</p>
          <p class="bs-website" data-field="website">makerfirst.ca</p>
          <p class="bs-license" data-field="licenseTag">CERN-OHL-S LICENSE</p>
        </div>
        <img src="/qr.svg" alt="QR code linking to MakerFirst" class="bs-qr" />
      </div>
    </section>
  </div>
</div>
