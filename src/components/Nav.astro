---
const navLinks = [
  { href: '#product', label: 'Product' },
  { href: '#manifesto', label: 'Manifesto' },
  { href: '#community', label: 'Community' },
];
---

<header class="fixed top-0 w-full z-50 bg-surface-dim/95 backdrop-blur-sm border-b border-outline">
  <!-- [WIDGET] Technical Label used in nav metadata -->
  <nav
    class="flex justify-between items-center px-4 h-16 max-w-[1440px] mx-auto"
    aria-label="Main navigation"
  >
    <a
      href="#"
      class="flex items-center gap-3 font-display font-bold text-lg tracking-tighter uppercase text-on-surface hover:text-primary transition-colors"
      style="transition-duration: var(--duration-fast);"
      aria-label="MakerFirst — home"
    >
      <img src="/logo.png" width="32" height="32" alt="" aria-hidden="true" class="rounded-[2px]" />
      MakerFirst
    </a>

    <ul class="hidden md:flex items-center gap-8 list-none m-0 p-0 font-display uppercase tracking-widest text-[11px]">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="text-on-surface-variant hover:text-primary transition-colors"
            style="transition-duration: var(--duration-fast);"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-4">
      <!-- [WIDGET] Version Badge -->
      <div class="hidden sm:flex items-center gap-2 px-2 py-1 bg-surface border border-outline rounded-[var(--radius)] font-display text-[10px] tracking-tighter text-on-surface-variant uppercase">
        <span class="status-dot"></span>
        OPEN SOURCE
      </div>
      <a
        href="#product"
        class="font-display uppercase tracking-widest text-[11px] text-primary hover:bg-primary/10 px-4 py-2 border border-primary/20 rounded-[var(--radius)] transition-colors"
        style="transition-duration: var(--duration-fast);"
      >
        Get Files
      </a>
    </div>
  </nav>
</header>